{
  "name": "restaurant-inventory-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant restaurant ordering and inventory SaaS MVP.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "db:up": "docker compose up -d postgres",
    "db:generate": "npm run generate -w packages/database",
    "db:migrate": "npm run migrate:dev -w packages/database --",
    "db:seed": "npm run seed -w packages/database",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run build -w packages/core && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
